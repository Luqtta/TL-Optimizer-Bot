# Discord
DISCORD_TOKEN=
# ID da APLICAÇÃO do bot (Developer Portal > General Information > Application ID).
CLIENT_ID=
# Registro dos slash commands (usado pelo deploy-commands / `npm run deploy`):
#  - GUILD_ONLY=true  + GUILD_ID=<servidor>  -> registra SÓ nesse servidor (aparece na HORA).
#  - GUILD_ONLY=false (ou vazio)             -> registra GLOBAL, em todo servidor onde o bot está
#                                               (pode levar até 1h pra sincronizar).
# Um comando registrado como guild NÃO aparece em outros servidores — foi isso que aconteceu
# ao trocar de servidor: re-rode o deploy com o GUILD_ID novo, OU deixe global.
GUILD_ID=
GUILD_ONLY=

# TL Optimizer API
TL_API_URL=http://localhost:3000
DISCORD_BOT_API_KEY=

# Webhooks
TL_WEBHOOK_SECRET=
WEBHOOK_PORT=3001

# Discord Roles (IDs)
ROLE_MONTHLY_ID=
ROLE_YEARLY_ID=
ROLE_LIFETIME_ID=

# Discord Channels (IDs)
FEATURE_CHANNEL_ID=
DISCORD_SYNC_LOG_CHANNEL_ID=
SHARE_CATEGORY_ID=
SUGGESTION_CHANNEL_ID=

# GitHub
GITHUB_WEBHOOK_SECRET=
